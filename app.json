{
  "expo": {
    "name": "Valeria+",
    "slug": "valeria-app",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "assets/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#00c4be"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00c4be",
          "defaultChannel": "valeria-recordatorios"
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Valeria+ usa el micrófono para los juegos de voz de los ejercicios.",
          "speechRecognitionPermission": "Valeria+ usa el reconocimiento de voz para valorar las palabras que dice el niño."
        }
      ],
      "./plugins/withSpeechRecognitionQueries",
      "./plugins/withJetifier"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "health.earlify.valeria"
    },
    "android": {
      "package": "health.earlify.valeria",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00c4be"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
