# ============================================================================
# Valeria+ · Variables de entorno de Firebase
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` (ignorado por git) y rellena los valores.
# Expo carga `.env` automáticamente y las variables EXPO_PUBLIC_* se inyectan
# en el bundle JS en tiempo de build.
#
# Los valores los imprime la Firebase CLI:
#   npx -y firebase-tools@latest apps:list ANDROID --project valeria-b500f
#   npx -y firebase-tools@latest apps:sdkconfig ANDROID <APP_ID> --project valeria-b500f
#
# IMPORTANTE: nunca escribas estos valores en archivos versionados. El secret
# scanning de GitHub marca las claves `AIzaSy…` aunque la web config de
# Firebase sea pública por diseño. Ver docs/firebase-setup.md.
# ============================================================================

# Clave del SDK web (formato AIzaSy…). Sale de `apps:sdkconfig`.
EXPO_PUBLIC_FIREBASE_API_KEY=

# ID del proyecto Firebase (público).
EXPO_PUBLIC_FIREBASE_PROJECT_ID=valeria-b500f

# Número del proyecto (público; messagingSenderId === project number).
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=477839657795

# App ID de la app Android (formato 1:<nº proyecto>:android:<hash>).
EXPO_PUBLIC_FIREBASE_APP_ID=
